      </item>
      <item row="2" column="1">
       <widget class="ctkPathLineEdit" name="bvecPathLineEdit">
        <property name="toolTip">
         <string>FSL-style .bvec file listing the gradient direction for each volume.</string>
        </property>
        <property name="nameFilters">
         <stringlist>
          <string>FSL b-vectors (*.bvec)</string>
          <string>All files (*)</string>
         </stringlist>
        </property>
        <property name="filters">
         <set>ctkPathLineEdit::Files|ctkPathLineEdit::Readable</set>
