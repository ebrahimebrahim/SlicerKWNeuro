       <widget class="QLabel" name="bvalLabel">
        <property name="text">
         <string>FSL bval file:</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="ctkPathLineEdit" name="bvalPathLineEdit">
        <property name="toolTip">
         <string>FSL-style .bval file listing the b-value for each gradient direction.</string>
        </property>
        <property name="nameFilters">
         <stringlist>
          <string>FSL b-values (*.bval)</string>
          <string>All files (*)</string>
         </stringlist>
