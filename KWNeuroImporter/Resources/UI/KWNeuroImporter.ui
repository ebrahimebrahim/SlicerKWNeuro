         <string>dwi</string>
        </property>
       </widget>
      </item>
      <item row="4" column="0" colspan="2">
       <widget class="QPushButton" name="loadButton">
        <property name="text">
         <string>Load DWI</string>
        </property>
        <property name="toolTip">
         <string>Read the three files from disk and push a vtkMRMLDiffusionWeightedVolumeNode into the scene using InSceneDwi.from_nifti_path. Unlike Slicer's built-in Add Data, this preserves the 4th dimension and attaches gradient + b-value metadata to the node.</string>
        </property>
        <property name="enabled">
         <bool>false</bool>
        </property>
       </widget>
