  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="ctkCollapsibleButton" name="importDwiCollapsibleButton">
     <property name="text">
      <string>Import DWI from disk</string>
     </property>
     <layout class="QFormLayout" name="importDwiFormLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="volumeLabel">
        <property name="text">
         <string>NIfTI volume:</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="ctkPathLineEdit" name="volumePathLineEdit">
        <property name="toolTip">
         <string>4D NIfTI file containing the diffusion-weighted volumes.</string>
        </property>
        <property name="nameFilters">
         <stringlist>
          <string>NIfTI (*.nii *.nii.gz)</string>
