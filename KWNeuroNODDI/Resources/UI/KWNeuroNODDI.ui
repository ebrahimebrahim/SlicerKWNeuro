<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>KWNeuroNODDI</class>
 <widget class="qMRMLWidget" name="KWNeuroNODDI">
  <property name="geometry"><rect><x>0</x><y>0</y><width>440</width><height>380</height></rect></property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="ctkCollapsibleButton" name="inputsCollapsibleButton">
     <property name="text"><string>Inputs</string></property>
     <layout class="QFormLayout" name="inputsFormLayout">
      <item row="0" column="0"><widget class="QLabel" name="inputDwiLabel"><property name="text"><string>Input DWI:</string></property></widget></item>
      <item row="0" column="1">
       <widget class="qMRMLNodeComboBox" name="inputDwiSelector">
        <property name="toolTip"><string>Multi-shell DWI for NODDI fitting. At least two non-zero b-shells are strongly recommended.</string></property>
        <property name="nodeTypes"><stringlist notr="true"><string>vtkMRMLDiffusionWeightedVolumeNode</string></stringlist></property>
        <property name="showChildNodeTypes"><bool>false</bool></property>
        <property name="addEnabled"><bool>false</bool></property>
        <property name="removeEnabled"><bool>false</bool></property>
        <property name="noneEnabled"><bool>false</bool></property>
       </widget>
      </item>
      <item row="1" column="0"><widget class="QLabel" name="maskLabel"><property name="text"><string>Brain mask (optional):</string></property></widget></item>
      <item row="1" column="1">
       <widget class="qMRMLNodeComboBox" name="maskSelector">
        <property name="toolTip"><string>Binary brain mask; restricts fitting to in-mask voxels.</string></property>
        <property name="nodeTypes"><stringlist notr="true"><string>vtkMRMLScalarVolumeNode</string><string>vtkMRMLLabelMapVolumeNode</string></stringlist></property>
        <property name="showChildNodeTypes"><bool>false</bool></property>
        <property name="addEnabled"><bool>false</bool></property>
        <property name="removeEnabled"><bool>false</bool></property>
        <property name="noneEnabled"><bool>true</bool></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="ctkCollapsibleButton" name="optionsCollapsibleButton">
     <property name="text"><string>Options</string></property>
     <layout class="QFormLayout" name="optionsFormLayout">
      <item row="0" column="0"><widget class="QLabel" name="dparLabel"><property name="text"><string>Parallel diffusivity (dpar, mm^2/s):</string></property></widget></item>
      <item row="0" column="1">
       <widget class="QDoubleSpinBox" name="dparSpinBox">
        <property name="decimals"><number>6</number></property>
        <property name="minimum"><double>0.0005</double></property>
        <property name="maximum"><double>0.005</double></property>
        <property name="singleStep"><double>0.0001</double></property>
        <property name="value"><double>0.0017</double></property>
        <property name="toolTip"><string>Parallel diffusivity for the NODDI kernel. Default 1.7e-3 (white matter). Use 1.3e-3 for gray matter. Range clamped to physically plausible values (5e-4 to 5e-3).</string></property>
       </widget>
      </item>
      <item row="1" column="0"><widget class="QLabel" name="nKernelDirsLabel"><property name="text"><string>Kernel directions:</string></property></widget></item>
      <item row="1" column="1">
       <widget class="QSpinBox" name="nKernelDirsSpinBox">
        <property name="minimum"><number>100</number></property>
        <property name="maximum"><number>2000</number></property>
        <property name="value"><number>500</number></property>
        <property name="toolTip"><string>Number of orientations used when generating AMICO NODDI kernels (over the half-sphere). Higher = slower but more accurate.</string></property>
       </widget>
      </item>
      <item row="2" column="0"><widget class="QLabel" name="outputsLabel"><property name="text"><string>Outputs:</string></property></widget></item>
      <item row="2" column="1">
       <widget class="QCheckBox" name="modulatedCheckBox">
        <property name="text"><string>Also create tissue-fraction-modulated NDI/ODI</string></property>
        <property name="checked"><bool>false</bool></property>
        <property name="toolTip"><string>When checked, additionally publishes `_ndi_mod` and `_odi_mod` volumes where the NDI/ODI are scaled by the tissue fraction (1-FWF). Useful for group analysis.</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QPushButton" name="applyButton">
     <property name="text"><string>Apply</string></property>
     <property name="toolTip"><string>Fit NODDI via AMICO. Requires kwneuro[noddi]. Produces NDI, ODI, FWF scalar volumes (+ modulated NDI/ODI if the checkbox is on).</string></property>
     <property name="enabled"><bool>false</bool></property>
    </widget>
   </item>
   <item>
    <widget class="QLabel" name="resultLabel">
     <property name="text"><string>(not run)</string></property>
     <property name="wordWrap"><bool>true</bool></property>
     <property name="textInteractionFlags"><set>Qt::TextSelectableByMouse</set></property>
    </widget>
   </item>
   <item>
    <spacer name="verticalSpacer">
     <property name="orientation"><enum>Qt::Vertical</enum></property>
     <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
    </spacer>
   </item>
  </layout>
 </widget>
 <customwidgets>
  <customwidget><class>qMRMLWidget</class><extends>QWidget</extends><header>qMRMLWidget.h</header><container>1</container></customwidget>
  <customwidget><class>qMRMLNodeComboBox</class><extends>QWidget</extends><header>qMRMLNodeComboBox.h</header></customwidget>
  <customwidget><class>ctkCollapsibleButton</class><extends>QWidget</extends><header>ctkCollapsibleButton.h</header><container>1</container></customwidget>
 </customwidgets>
 <resources/>
 <connections>
  <connection><sender>KWNeuroNODDI</sender><signal>mrmlSceneChanged(vtkMRMLScene*)</signal><receiver>inputDwiSelector</receiver><slot>setMRMLScene(vtkMRMLScene*)</slot></connection>
  <connection><sender>KWNeuroNODDI</sender><signal>mrmlSceneChanged(vtkMRMLScene*)</signal><receiver>maskSelector</receiver><slot>setMRMLScene(vtkMRMLScene*)</slot></connection>
 </connections>
</ui>
