<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>KWNeuroCSD</class>
 <widget class="qMRMLWidget" name="KWNeuroCSD">
  <property name="geometry"><rect><x>0</x><y>0</y><width>440</width><height>380</height></rect></property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="ctkCollapsibleButton" name="inputsCollapsibleButton">
     <property name="text"><string>Inputs</string></property>
     <layout class="QFormLayout" name="inputsFormLayout">
      <item row="0" column="0"><widget class="QLabel" name="inputDwiLabel"><property name="text"><string>Input DWI:</string></property></widget></item>
      <item row="0" column="1">
       <widget class="qMRMLNodeComboBox" name="inputDwiSelector">
        <property name="toolTip"><string>DWI for CSD peak computation. The fiber orientation distribution is estimated per voxel.</string></property>
        <property name="nodeTypes"><stringlist notr="true"><string>vtkMRMLDiffusionWeightedVolumeNode</string></stringlist></property>
        <property name="showChildNodeTypes"><bool>false</bool></property>
        <property name="addEnabled"><bool>false</bool></property>
        <property name="removeEnabled"><bool>false</bool></property>
        <property name="noneEnabled"><bool>false</bool></property>
       </widget>
      </item>
      <item row="1" column="0"><widget class="QLabel" name="maskLabel"><property name="text"><string>Brain mask:</string></property></widget></item>
      <item row="1" column="1">
       <widget class="qMRMLNodeComboBox" name="maskSelector">
        <property name="toolTip"><string>Binary brain mask. CSD is only computed inside the mask.</string></property>
        <property name="nodeTypes"><stringlist notr="true"><string>vtkMRMLScalarVolumeNode</string><string>vtkMRMLLabelMapVolumeNode</string></stringlist></property>
        <property name="showChildNodeTypes"><bool>false</bool></property>
        <property name="addEnabled"><bool>false</bool></property>
        <property name="removeEnabled"><bool>false</bool></property>
        <property name="noneEnabled"><bool>false</bool></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="ctkCollapsibleButton" name="optionsCollapsibleButton">
     <property name="text"><string>Options</string></property>
     <layout class="QFormLayout" name="optionsFormLayout">
      <item row="0" column="0"><widget class="QLabel" name="nPeaksLabel"><property name="text"><string>Peaks per voxel:</string></property></widget></item>
      <item row="0" column="1">
       <widget class="QSpinBox" name="nPeaksSpinBox">
        <property name="minimum"><number>1</number></property>
        <property name="maximum"><number>10</number></property>
        <property name="value"><number>5</number></property>
        <property name="toolTip"><string>Maximum number of CSD peaks extracted per voxel.</string></property>
       </widget>
      </item>
      <item row="1" column="0"><widget class="QLabel" name="flipXLabel"><property name="text"><string>Flip bvecs X:</string></property></widget></item>
      <item row="1" column="1">
       <widget class="QCheckBox" name="flipBvecsXCheckBox">
        <property name="text"><string>(match MRtrix3 convention)</string></property>
        <property name="checked"><bool>true</bool></property>
        <property name="toolTip"><string>Flip the x-component of b-vectors. Default on to match MRtrix3 convention; disable if your data is already MRtrix-convention.</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QPushButton" name="applyButton">
     <property name="text"><string>Compute CSD peaks</string></property>
     <property name="toolTip"><string>Estimate single-tissue response function from low-b data, fit CSD, and extract peaks. Produces a 4D vector volume of shape (x, y, z, n_peaks*3) where each voxel holds n_peaks (x,y,z) vectors whose magnitude equals the peak value.</string></property>
     <property name="enabled"><bool>false</bool></property>
    </widget>
   </item>
   <item>
    <widget class="QLabel" name="resultLabel">
     <property name="text"><string>(not run)</string></property>
     <property name="wordWrap"><bool>true</bool></property>
     <property name="textInteractionFlags"><set>Qt::TextSelectableByMouse</set></property>
    </widget>
   </item>
   <item>
    <spacer name="verticalSpacer">
     <property name="orientation"><enum>Qt::Vertical</enum></property>
     <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
    </spacer>
   </item>
  </layout>
 </widget>
 <customwidgets>
  <customwidget><class>qMRMLWidget</class><extends>QWidget</extends><header>qMRMLWidget.h</header><container>1</container></customwidget>
  <customwidget><class>qMRMLNodeComboBox</class><extends>QWidget</extends><header>qMRMLNodeComboBox.h</header></customwidget>
  <customwidget><class>ctkCollapsibleButton</class><extends>QWidget</extends><header>ctkCollapsibleButton.h</header><container>1</container></customwidget>
 </customwidgets>
 <resources/>
 <connections>
  <connection><sender>KWNeuroCSD</sender><signal>mrmlSceneChanged(vtkMRMLScene*)</signal><receiver>inputDwiSelector</receiver><slot>setMRMLScene(vtkMRMLScene*)</slot></connection>
  <connection><sender>KWNeuroCSD</sender><signal>mrmlSceneChanged(vtkMRMLScene*)</signal><receiver>maskSelector</receiver><slot>setMRMLScene(vtkMRMLScene*)</slot></connection>
 </connections>
</ui>
