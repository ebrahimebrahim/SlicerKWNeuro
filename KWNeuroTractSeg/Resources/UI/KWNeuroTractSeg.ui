 </customwidgets>
 <resources/>
 <connections>
  <connection><sender>KWNeuroTractSeg</sender><signal>mrmlSceneChanged(vtkMRMLScene*)</signal><receiver>inputDwiSelector</receiver><slot>setMRMLScene(vtkMRMLScene*)</slot></connection>
  <connection><sender>KWNeuroTractSeg</sender><signal>mrmlSceneChanged(vtkMRMLScene*)</signal><receiver>maskSelector</receiver><slot>setMRMLScene(vtkMRMLScene*)</slot></connection>
